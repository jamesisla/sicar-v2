# ─── Base de datos ────────────────────────────────────────────
# Tipo: postgres | oracle | mysql | sqlite
DB_TYPE=postgres
DB_HOST=postgres          # nombre del servicio Docker en producción
DB_PORT=5432
DB_USER=sicar
DB_PASSWORD=sicar123      # CAMBIAR en producción
DB_NAME=sicar_v2
DB_SYNC=false
DB_LOGGING=false
DB_SSL=false

# Para Oracle (producción con Oracle DB):
# DB_TYPE=oracle
# DB_HOST=oracle-host
# DB_PORT=1521
# DB_NAME=SICAR
# DB_USER=mbnowner
# DB_PASSWORD=

# ─── JWT ──────────────────────────────────────────────────────
# IMPORTANTE: Cambiar por valores aleatorios largos en producción
# Generar con: openssl rand -hex 64
JWT_SECRET=cambia-esto-en-produccion
JWT_REFRESH_SECRET=cambia-esto-refresh-en-produccion

# ─── SIGFE (integración contable) ─────────────────────────────
SIGFE_URL=
SIGFE_USUARIO=
SIGFE_CODIGO_INSTITUCION=
SIGFE_CORREO_NOTIFICACION=
SIGFE_PARTIDA=
SIGFE_CAPITULO=
SIGFE_AREA_TRANSACCIONAL=

# ─── TGR (pagos en línea) ─────────────────────────────────────
TGR_URL=
TGR_API_KEY=

# ─── App ──────────────────────────────────────────────────────
PORT=3001
# En producción con Nginx: CORS_ORIGINS=http://tu-dominio-o-ip
CORS_ORIGINS=http://localhost:3000
NODE_ENV=development
